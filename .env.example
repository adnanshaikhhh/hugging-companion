# Hugging Companion — environment template
# Copy to .env and fill in. None of these are required for the demo to run.

# OpenAI — when set, the companion uses gpt-4o-mini for plans/summaries/recall.
# When unset, it falls back to a deterministic template engine.
OPENAI_API_KEY=

# Override defaults if you want
HUGGING_COMPANION_APP_NAME="Hugging Companion"
HUGGING_COMPANION_DB_URL=sqlite:///./data/hugging_companion.db
HUGGING_COMPANION_DEFAULT_DURATION_MIN=25
HUGGING_COMPANION_LOG_LEVEL=info